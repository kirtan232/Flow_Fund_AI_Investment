# Local MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=flowfund_auth_test

# Railway: use this instead of DB_* (copy from Railway MySQL service variables)
# MYSQL_PUBLIC_URL=mysql://root:xxx@turntable.proxy.rlwy.net:11318/railway

JWT_SECRET=your_super_secret_key_here
PORT=5000

# Bank Aggregator API (Plaid Sandbox for development)
# Get these from your Plaid dashboard: https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox

# AES-256-GCM key for encrypting stored aggregator tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_TOKEN_KEY=your_64_char_hex_key_here
